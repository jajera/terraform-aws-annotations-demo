# enable_scheduler = true
# schedule_time    = "2026-06-19T08:00:00"  # future UTC, format YYYY-MM-DDTHH:mm:ss

# deploy_amplify_on_apply = true  # set false to skip frontend build on apply

# enable_dynamodb = false
